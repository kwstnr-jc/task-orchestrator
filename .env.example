# ── Postgres ──────────────────────────────────────────────
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=orchestrator
POSTGRES_PASSWORD=changeme
POSTGRES_DB=orchestrator
DATABASE_URL=postgres://orchestrator:changeme@postgres:5432/orchestrator?sslmode=disable

# ── Auth0 ─────────────────────────────────────────────────
AUTH0_DOMAIN=your-tenant.auth0.com
AUTH0_CLIENT_ID=your-client-id
AUTH0_CLIENT_SECRET=your-client-secret
AUTH0_CALLBACK_URL=http://localhost:8080/api/auth/callback

# ── Session ───────────────────────────────────────────────
SESSION_SECRET=generate-a-random-32-byte-hex-string
COOKIE_DOMAIN=localhost

# ── Allowlists (comma-separated) ─────────────────────────
ALLOWED_USERS=kwstnr
ALLOWED_MACHINES=mac-mini

# ── SQS ───────────────────────────────────────────────────
AWS_REGION=eu-central-1
SQS_QUEUE_URL=https://sqs.eu-central-1.amazonaws.com/123456789/task-queue

# ── Machine Auth ─────────────────────────────────────────
# Static API key for machine-to-machine auth (daily-digest, daemon)
# Generate with: openssl rand -base64 32
API_KEY=

# ── Dev ──────────────────────────────────────────────────
# Set to "true" to bypass Auth0 login (injects a fake dev user)
DEV_MODE=false

# ── Server ────────────────────────────────────────────────
PORT=8080
CORS_ORIGIN=http://localhost:5173
